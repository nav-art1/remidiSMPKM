                { q: "Sebuah poster digital dikategorikan memiliki susunan 'Keseimbangan Simetris' apabila...", opts: ["Elemen visual di area kanan dan kiri sumbu pembagi memiliki bobot komposisi yang setara atau serupa.", "Penempatan elemen dilakukan secara acak tanpa mengikuti garis sumbu.", "Terdapat satu gambar besar di sisi kiri dan tidak ada elemen di sisi kanan.", "Warna latar belakang dibuat lebih gelap dari objek utama."], ans: 0 },
                { q: "Indikator utama yang membedakan operasional Google Spreadsheet dibandingkan dengan Microsoft Excel versi desktop adalah...", opts: ["Memiliki rumus matematika yang jauh lebih sedikit dan terbatas.", "Menggunakan kode pemrograman rumit untuk memasukkan data numerik.", "Bisa dijalankan langsung melalui web browser secara online serta mendukung kolaborasi kelompok secara real-time.", "Hanya dikhususkan untuk mengolah data dalam format teks atau gambar saja."], ans: 2 },
                { q: "Mengapa sebuah tampilan slide presentasi pembelajaran disarankan untuk menerapkan konsep 'Sederhana'?", opts: ["Agar presenter bisa menyalin seluruh isi buku pelajaran ke dalam satu halaman slide.", "Meminimalkan gangguan visual sehingga audiens dapat menangkap substansi pesan tanpa perlu berpikir terlalu keras.", "Memperbanyak ruang kosong agar durasi presentasi berjalan lebih lambat.", "Menghilangkan kebutuhan penggunaan grafik atau gambar penunjang materi."], ans: 1 }
            ]
        };

        const mapelNames = {
            ipa7: "Remedial IPA Kelas 7",
            ipa8: "Remedial IPA Kelas 8",
            prakarya8: "Remedial Prakarya Kelas 8",
            infor7: "Remedial Informatika Kelas 7"
        };

        // 1. Tambahkan variabel global untuk mencatat waktu
        let waktuMulai = '';
        let waktuSelesai = '';

        let currentSoalData = [];
        let answers = [];
        let currentQuestionIndex = 0;
        let cheatCount = 0;
        let isExamActive = false;
        let studentData = { username: '', nama: '', kelas: '', mapel: '' };

        // Proses Login & Validasi Tingkat Kelas
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const inputUser = document.getElementById('inputUsername').value.toLowerCase();
            const inputPass = document.getElementById('inputPassword').value;
            const errorMsg = document.getElementById('loginError');

            if(dataSiswa[inputUser] && dataSiswa[inputUser].pass === inputPass) {
                errorMsg.classList.add('hidden');
                
                // Simpan data siswa ke memory
                studentData.username = inputUser;
                studentData.nama = dataSiswa[inputUser].nama;
                studentData.kelas = dataSiswa[inputUser].kelas;
                
                showMapelSelection();
            } else {
                errorMsg.classList.remove('hidden');
            }
        });

        // Transisi ke Pilihan Mata Pelajaran
        function showMapelSelection() {
            document.getElementById('loginSection').classList.add('hidden');
            document.getElementById('mapelSection').classList.remove('hidden');
            
            document.getElementById('welcomeName').innerText = studentData.nama;
            document.getElementById('welcomeKelas').innerText = studentData.kelas;

            const mapelContainer = document.getElementById('mapelButtons');
            mapelContainer.innerHTML = '';

            // Menampilkan tombol sesuai kelas siswa yang login
            if(studentData.kelas === 7) {
                mapelContainer.innerHTML += `<button onclick="startExam('ipa7')" class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-4 rounded-xl shadow-lg transition transform hover:-translate-y-1 text-lg">🌿 Remedial IPA (Kelas 7)</button>`;
                mapelContainer.innerHTML += `<button onclick="startExam('infor7')" class="w-full bg-indigo-500 hover:bg-indigo-600 text-white font-bold py-4 px-4 rounded-xl shadow-lg transition transform hover:-translate-y-1 text-lg">💻 Remedial Informatika (Kelas 7)</button>`;
            } else if (studentData.kelas === 8) {
                mapelContainer.innerHTML += `<button onclick="startExam('ipa8')" class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-4 rounded-xl shadow-lg transition transform hover:-translate-y-1 text-lg">🌿 Remedial IPA (Kelas 8)</button>`;
                mapelContainer.innerHTML += `<button onclick="startExam('prakarya8')" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-4 px-4 rounded-xl shadow-lg transition transform hover:-translate-y-1 text-lg">🔨 Remedial Prakarya (Kelas 8)</button>`;
            }
        }

        // Fungsi Logout / Kembali ke halaman awal
        function logout() {
            document.getElementById('loginSection').classList.remove('hidden');
            document.getElementById('mapelSection').classList.add('hidden');
            document.getElementById('loginForm').reset();
            document.getElementById('loginError').classList.add('hidden');
            studentData = { username: '', nama: '', kelas: '', mapel: '' };
        }

        // 2. Modifikasi fungsi startExam() untuk mencatat waktu mulai
        function startExam(mapelCode) {
            studentData.mapel = mapelCode;
            let rawSoal = dbSoal[studentData.mapel];
            
            // Pengacakan urutan soal dan urutan opsi jawaban
            currentSoalData = JSON.parse(JSON.stringify(rawSoal)).map(q => {
                let correctAnswerText = q.opts[q.ans];
                for (let i = q.opts.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [q.opts[i], q.opts[j]] = [q.opts[j], q.opts[i]];
                }
                q.ans = q.opts.indexOf(correctAnswerText);
                return q;
            });

            for (let i = currentSoalData.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [currentSoalData[i], currentSoalData[j]] = [currentSoalData[j], currentSoalData[i]];
            }

            answers = new Array(currentSoalData.length).fill(null);
            currentQuestionIndex = 0;
            cheatCount = 0;

            document.getElementById('homeScreen').classList.add('hidden');
            document.getElementById('quizScreen').classList.replace('hidden', 'flex');
            
            document.getElementById('headerName').innerText = studentData.nama;
            document.getElementById('headerMapel').innerText = mapelNames[studentData.mapel];
            document.getElementById('totalQNumber').innerText = currentSoalData.length;

            // Catat waktu saat tombol mulai ujian ditekan
            waktuMulai = new Date().toLocaleString('id-ID'); 

            isExamActive = true;
            requestFullscreen();
            renderQuestion();
            renderGrid();
        }

        function renderQuestion() {
            const qData = currentSoalData[currentQuestionIndex];
            document.getElementById('currentQNumber').innerText = currentQuestionIndex + 1;
            document.getElementById('questionText').innerText = qData.q;
            
            const optsContainer = document.getElementById('optionsContainer');
            optsContainer.innerHTML = '';
            const abcd = ['A', 'B', 'C', 'D'];

            qData.opts.forEach((opt, idx) => {
                const isSelected = answers[currentQuestionIndex] === idx;
                const label = document.createElement('label');
                label.className = `option-label flex items-start gap-4 p-4 rounded-xl border-2 cursor-pointer transition-all ${isSelected ? 'bg-blue-50 border-blue-500' : 'bg-white border-slate-200 hover:border-blue-300 hover:bg-slate-50'}`;
                
                const input = document.createElement('input');
                input.type = 'radio';
                input.name = 'option';
                input.value = idx;
                input.className = 'mt-1 w-5 h-5 text-blue-600 focus:ring-blue-500';
                input.checked = isSelected;
                input.onchange = () => selectAnswer(idx);

                const textSpan = document.createElement('span');
                textSpan.className = 'flex-1 text-slate-700 font-medium';
                textSpan.innerHTML = `<strong class="text-blue-700">${abcd[idx]}.</strong> ${opt}`;
                
                label.appendChild(input);
                label.appendChild(textSpan);
                optsContainer.appendChild(label);
            });

            document.getElementById('btnPrev').disabled = currentQuestionIndex === 0;
            document.getElementById('btnNext').disabled = currentQuestionIndex === currentSoalData.length - 1;
            checkSubmitCapability();
        }

        function selectAnswer(optIdx) {
            answers[currentQuestionIndex] = optIdx;
            renderQuestion();
            renderGrid();
        }

        function nextQuestion() {
            if (currentQuestionIndex < currentSoalData.length - 1) {
                currentQuestionIndex++;
                renderQuestion();
            }
        }

        function prevQuestion() {
            if (currentQuestionIndex > 0) {
                currentQuestionIndex--;
                renderQuestion();
            }
        }

        function renderGrid() {
            const grid = document.getElementById('numberGrid');
            grid.innerHTML = '';
            for (let i = 0; i < currentSoalData.length; i++) {
                const btn = document.createElement('button');
                btn.innerText = i + 1;
                let baseClass = "w-full aspect-square rounded-lg font-bold border-2 flex items-center justify-center transition ";
                if (answers[i] !== null) baseClass += "bg-blue-100 border-blue-300 text-blue-700";
                else baseClass += "bg-white border-slate-200 text-slate-600";
                if (i === currentQuestionIndex) baseClass += " ring-2 ring-offset-1 ring-blue-500 scale-105";
                btn.className = baseClass;
                btn.onclick = () => { currentQuestionIndex = i; renderQuestion(); toggleGrid(); };
                grid.appendChild(btn);
            }
        }

        function toggleGrid() {
            const menu = document.getElementById('gridMenu');
            const overlay = document.getElementById('gridOverlay');
            if (menu.classList.contains('translate-x-full')) {
                menu.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
            } else {
                menu.classList.add('translate-x-full');
                overlay.classList.add('hidden');
            }
        }

        function checkSubmitCapability() {
            const isAllAnswered = answers.every(ans => ans !== null);
            const btnSubmit = document.getElementById('btnSubmit');
            const warning = document.getElementById('submitWarning');
            const btnSubmitMain = document.getElementById('btnSubmitMain');
            
            if (isAllAnswered) {
                btnSubmit.disabled = false;
                btnSubmit.classList.replace('bg-gray-400', 'bg-green-500');
                warning.classList.add('hidden');
                if(btnSubmitMain) btnSubmitMain.classList.remove('hidden');
            } else {
                btnSubmit.disabled = true;
                btnSubmit.classList.add('bg-gray-400');
                warning.classList.remove('hidden');
                if(btnSubmitMain) btnSubmitMain.classList.add('hidden');
            }
        }

        function submitExam() {
            const menu = document.getElementById('gridMenu');
            if (!menu.classList.contains('translate-x-full')) toggleGrid();
            document.getElementById('confirmSubmitModal').classList.remove('hidden');
        }

        function closeConfirmModal() { document.getElementById('confirmSubmitModal').classList.add('hidden'); }

        function executeSubmit() {
            closeConfirmModal();
            isExamActive = false;
            
            try {
                const isInFullscreen = !!(document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement);
                if (isInFullscreen) {
                    const exitFunc = document.exitFullscreen || document.webkitExitFullscreen || document.mozCancelFullScreen || document.msExitFullscreen;
                    if (exitFunc) exitFunc.call(document).catch(() => {});
                }
            } catch (err) {}
            
            calculateAndShowResult();
        }

        // 3. Modifikasi fungsi calculateAndShowResult()
        function calculateAndShowResult() {
            waktuSelesai = new Date().toLocaleString('id-ID'); // Catat waktu selesai
            
            let correct = 0;
            let detailJawaban = []; // Array untuk menampung 1 dan 0
            
            for (let i = 0; i < currentSoalData.length; i++) {
                if (answers[i] === currentSoalData[i].ans) { 
                    correct++; 
                    detailJawaban.push(1); // Jika benar, masukkan angka 1
                } else {
                    detailJawaban.push(0); // Jika salah, masukkan angka 0
                }
            }
            
            // Hitung nilai maksimal 100
            const score = Math.round((correct / currentSoalData.length) * 100);
            
            document.getElementById('quizScreen').classList.replace('flex', 'hidden');
            document.getElementById('resultScreen').classList.remove('hidden');
            document.getElementById('resName').innerText = studentData.nama;
            document.getElementById('resMapel').innerText = mapelNames[studentData.mapel];
            document.getElementById('resScore').innerText = score;
            document.getElementById('resCorrect').innerText = correct;
            document.getElementById('resWrong').innerText = currentSoalData.length - correct;
            document.getElementById('resCheat').innerText = cheatCount + " Kali";
            
            if(score >= 75) {
                document.getElementById('resultEmoji').innerText = "🥳";
            } else {
                document.getElementById('resultEmoji').innerText = "💪";
            }

            // Panggil fungsi untuk mengirim data
            kirimDataKeSpreadsheet(score, detailJawaban);
        }

        // 4. Tambahkan fungsi fetch untuk mengirim ke Google Sheets
        function kirimDataKeSpreadsheet(score, detailJawaban) {
            // URL Web App dari Google Apps Script yang baru
            const urlAppsScript = "https://script.google.com/macros/s/AKfycbwg2PEQ4sacnuE95j4raJ-JIrOLaC8-t4ZTieuJbArYHa9ENdbgbYxRX-9fDpkuQKoJ/exec"; 

            const payload = {
                nama: studentData.nama,
                kelas: studentData.kelas,
                mapel: mapelNames[studentData.mapel],
                pelanggaran: cheatCount,
                nilai: score,
                waktuMulai: waktuMulai,
                waktuSelesai: waktuSelesai,
                detailJawaban: JSON.stringify(detailJawaban) // Ubah array ke string agar aman dikirim
            };

            fetch(urlAppsScript, {
                method: 'POST',
                mode: 'no-cors', // Penting untuk menghindari error CORS
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            }).then(() => {
                console.log("Data berhasil dikirim ke Spreadsheet!");
            }).catch((error) => {
                console.error("Gagal mengirim data:", error);
            });
        }

        function resetApp() {
            document.getElementById('resultScreen').classList.add('hidden');
            document.getElementById('homeScreen').classList.remove('hidden');
            logout(); // Reset ke awal halaman login
        }

        function requestFullscreen() {
            const e = document.documentElement;
            if (e.requestFullscreen) e.requestFullscreen().catch(() => {});
            else if (e.webkitRequestFullscreen) e.webkitRequestFullscreen().catch(() => {});
        }
        
        function triggerCheatWarning() {
            if (!isExamActive) return;
            cheatCount++;
            document.getElementById('warningModal').classList.remove('hidden');
        }
        
        function closeWarning() {
            document.getElementById('warningModal').classList.add('hidden');
            requestFullscreen();
        }
        
        document.addEventListener('visibilitychange', () => { if(document.hidden && isExamActive) triggerCheatWarning(); });
        window.addEventListener('blur', () => { if(isExamActive) triggerCheatWarning(); });
        document.addEventListener('fullscreenchange', () => { if(!document.fullscreenElement && isExamActive) triggerCheatWarning(); });
    </script>
</body>
</html>
